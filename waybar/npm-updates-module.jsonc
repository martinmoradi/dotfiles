{
  "custom/npm-updates": {
    "format": "\uf3b9  {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.local/bin/dot npm waybar",
    "interval": 1800,
    "signal": 7,
    "hide-empty-text": true,
    "on-click": "~/.config/ml4w/settings/install-npm-updates.sh",
    "on-click-right": "~/.local/bin/dot npm status"
  }
}
