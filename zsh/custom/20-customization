# Overrides ML4W's 20-customization, which assumed ~/.oh-my-zsh (doesn't exist).
# Uses the system OMZ at /usr/share/oh-my-zsh instead.
# -----------------------------------------------------

export ZSH="/usr/share/oh-my-zsh"
DISABLE_AUTO_UPDATE="true"    # We update OMZ via pacman (oh-my-zsh-git)
COMPLETION_WAITING_DOTS="true"

plugins=(
    sudo                    # Esc+Esc to prepend/strip sudo
    colored-man-pages       # Colorize man pages
    extract                 # `x file.tar.gz` - universal archive extractor
    fancy-ctrl-z            # Ctrl+Z to toggle foreground/background
    safe-paste              # Multiline paste safety: newlines don't auto-execute
    fzf                     # Ctrl+R fuzzy history, Ctrl+T file, Alt+C cd
    history-substring-search # Up/down arrow searches history by typed prefix
    kitty                   # Kitty terminal completions
    bun                     # Bun completions
    copybuffer              # Ctrl+O copies current cmdline to clipboard
    copyfile                # `copyfile <file>` copies file content
    copypath                # `copypath` copies current path
    dirhistory              # Alt+Left/Right/Up for directory nav history
    zoxide                  # Smart cd - `z <partial-name>` jumps to frecent dirs
)

source "$ZSH/oh-my-zsh.sh"

# System zsh plugins (not bundled in OMZ; installed as system packages)
[[ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
    source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

[[ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
    source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# FZF shell integration (Ctrl+R, Ctrl+T, Alt+C)
source <(fzf --zsh)

# History
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory

# mise - per-directory tool versions (auto-switches Node/etc. via mise.toml)
command -v mise &>/dev/null && eval "$(mise activate zsh)"

# Prompt - oh-my-posh with your zen theme
eval "$(oh-my-posh init zsh --config $HOME/.config/ohmyposh/zen.toml)"
