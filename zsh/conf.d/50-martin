  g        git
  gs       git status --short --branch
  gd       git diff
  gds      git diff --staged
  ga       git add
  gc       git commit
  gc-ai    use low-effort Codex for semantic commits, no edits, no push
  gcm      git commit -m
  gp       git push
  gpl      git pull --ff-only
  gf       git fetch --all --prune
  gprune   git fetch --all --prune
  gfp      git fetch --all --prune && git pull --ff-only
  gl       git log --oneline --decorate --graph
  gsw      git switch
  gnew     git switch -c
