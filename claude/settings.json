{
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/martin/.claude/hooks/bash-guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/martin/.claude/hooks/auto-format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/martin/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "cloudflare@cloudflare": true,
    "frontend-design@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "bencium-innovative-ux-designer@bencium-marketplace": false,
    "gsap-skills@gsap-skills": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    },
    "bencium-marketplace": {
      "source": {
        "source": "github",
        "repo": "bencium/bencium-marketplace"
      }
    },
    "gsap-skills": {
      "source": {
        "source": "github",
        "repo": "greensock/gsap-skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true
}
