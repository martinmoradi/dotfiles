#!/usr/bin/env python3
"""dot - front door for this dotfiles repo.

One engine, two front-ends:
  * scriptable CLI: dot deploy [modules...] [--dry-run], status, diff, snapshot, sync
  * interactive TUI: `dot` with no args (curses; tabs + checkboxes + drift markers)

The module registry below is the structure that used to be hard-coded as a
linear deploy.sh. Each module is an ordered list of typed steps; deploy.sh and
snapshot.sh are now thin shims that exec this tool.
"""

import argparse
import curses
import difflib
import hashlib
import json
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass, field
from enum import Enum
from pathlib import Path
from typing import Callable, List, Optional

# --- paths (module-level; independent of argv) ------------------------------

REPO = Path(__file__).resolve().parent          # resolve() follows the ~/.local/bin/dot symlink
HOME = Path.home()
LB = HOME / ".local" / "bin"
CFG = Path(os.environ.get("XDG_CONFIG_HOME") or (HOME / ".config"))
CLAUDE = HOME / ".claude"


# --- data model -------------------------------------------------------------

class Kind(Enum):
    COPY = "copy"               # file -> file (drift = hash/mode mismatch)
    DIR_SYNC = "dir_sync"       # dir -> dir, mirror with delete (drift = tree diff)
    SYMLINK = "symlink"         # ln -sf src -> dst
    MKDIR = "mkdir"             # ensure an otherwise-empty dir exists
    GEN_IF_MISSING = "gen"      # write generated content only if target empty/missing
    LEGACY_RM = "legacy_rm"     # remove a stale file (drift = still present)
    ACTION = "action"           # opaque post-action; can only run, never diffed
    TOGGLE = "toggle"           # interactive live-state switch (TUI only; deploy skips)


# status states
IN_SYNC = "in-sync"
DRIFTED = "drifted"
NEW = "not-deployed"
SKIPPED = "skipped"
ACTION_ONLY = "action"


@dataclass
class Guard:
    target_exists: Optional[Path] = None   # deployed target must already exist
    repo_exists: Optional[Path] = None     # repo-side source must exist
    command: Optional[str] = None          # command -v <command>
    sudo_n: bool = False                   # passwordless `sudo -n true`


@dataclass
class Step:
    kind: Kind
    label: str
    src: Optional[Path] = None
    dst: Optional[Path] = None
    executable: bool = False               # chmod +x the deployed file/source
    snapshot: bool = False                 # also pulled back by `dot snapshot`
    guard: Guard = field(default_factory=Guard)
    run_argv: Optional[List[str]] = None   # ACTION: subprocess to run
    run: Optional[Callable[[], None]] = None  # ACTION: python callable
    dry_note: str = ""                     # ACTION: what --dry-run prints
    skip_hint: str = ""                    # printed when a guard skips the step
    generator: Optional[Callable[[], str]] = None  # GEN_IF_MISSING content
    exec_glob: Optional[str] = None        # DIR_SYNC: chmod +x matches after sync
    interactive_only: bool = False         # shown/runnable in TUI, skipped by deploy
    detect: Optional[Callable[[], str]] = None     # TOGGLE: returns current mode key
    transitions: Optional[dict] = None     # TOGGLE: mode -> {desc, action, argv}


@dataclass
class Module:
    name: str
    summary: str
    steps: List[Step]


@dataclass
class Status:
    state: str
    detail: str = ""


# --- ACTION callables -------------------------------------------------------

def gen_current_project() -> str:
    """First registered project path, for the initial current-project pointer."""
    try:
        data = json.loads((CFG / "dev" / "projects.json").read_text())
    except (OSError, ValueError):
        return ""
    return f'{data[0]["path"]}\n' if data else ""


def enable_coolify_timer() -> None:
    subprocess.run(["systemctl", "--user", "daemon-reload"], check=False)
    subprocess.run(
        ["systemctl", "--user", "enable", "--now", "coolify-staging-notify.timer"],
        check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )


def detect_waybar_mode() -> str:
    """split = my config (split-monitor-workspaces); vanilla = plugin disabled."""
    try:
        data = json.loads((CFG / "waybar/modules.json").read_text())
    except (OSError, ValueError):
        return "unknown"
    on_scroll = data.get("hyprland/workspaces", {}).get("on-scroll-up", "")
    if "split-cycleworkspaces" in on_scroll:
        return "split"
    if "workspace" in on_scroll:
        return "vanilla"
    return "unknown"


