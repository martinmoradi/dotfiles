    return npm_item_label(item) if item else fallback


def npm_package_status_for_tui(name: str) -> Status:
    item = npm_package_for_tui(name)
    return npm_package_status(item) if item else Status(SKIPPED, "not tracked")


def npm_refresh_action() -> None:
