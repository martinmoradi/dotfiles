    npm_refresh_waybar()
    print_npm_summary(data)


def print_npm_summary(data: dict, heading: bool = True) -> None:
    counts = data["counts"]
    if heading:
        print("npm globals")
    print(f"  tracked:   {counts['tracked']}")
    print(f"  in sync:   {counts['in_sync']}")
    print(f"  outdated:  {counts['outdated']}")
    print(f"  missing:   {counts['missing']}")
    print(f"  untracked: {counts['untracked']}")
    if data.get("errors"):
        print(f"  errors:    {len(data['errors'])}")


def print_npm_status(data: dict) -> None:
    print("npm globals\n")
    doctor = data.get("doctor") or {}
    prefix = doctor.get("prefix") or "unknown"
    print(f"  tracked file: {NPM_GLOBALS_FILE.relative_to(REPO)}")
    print(f"  cache:        {NPM_STATUS_CACHE}")
    print(f"  npm prefix:   {prefix}")
    for warning in doctor.get("warnings") or []:
        print(f"  ! {warning}")
    print()

    if data["packages"]:
        print("  tracked")
        for item in data["packages"]:
            print(f"    {npm_item_label(item)}")
    else:
        print("  tracked")
        print("    none")

    if data["untracked"]:
        print("\n  untracked")
        for item in data["untracked"]:
            print(f"    {item['name']} {item['installed']}  adopt with: {item['adopt_command']}")

    for warning in data.get("warnings") or []:
        print(f"\n  warning: {warning}")
    for error in data.get("errors") or []:
        print(f"\n  error: {error}")

    print()
    print_npm_summary(data, heading=False)


def npm_waybar_payload(data: dict) -> dict:
    counts = data.get("counts") or {}
    actionable = int(counts.get("actionable") or 0)
    errors = list(data.get("errors") or [])
    doctor_warnings = (data.get("doctor") or {}).get("warnings") or []
    if errors or (data.get("doctor") or {}).get("needs_prefix_fix"):
        tooltip_lines = ["npm globals need attention", *errors, *doctor_warnings]
        return {"text": "!", "alt": "error", "tooltip": "\n".join(tooltip_lines), "class": "red"}
    if actionable == 0:
        return {"text": "", "alt": "0", "tooltip": "Tracked npm globals are in sync"}

    lines = []
    for item in data.get("packages", []):
        if item.get("state") == "outdated":
            lines.append(f"{item['name']} {item['installed']} -> {item['latest']}")
        elif item.get("state") == "missing":
            lines.append(f"{item['name']} missing latest {item.get('latest') or 'unknown'}")
    return {
        "text": str(actionable),
        "alt": str(actionable),
        "tooltip": "\n".join(lines) if lines else f"{actionable} npm globals need updates",
    }


def ml4w_color(name: str) -> Optional[str]:
    try:
        value = (CFG / "ml4w/colors" / name).read_text().strip()
    except OSError:
        return None
    return value or None


def npm_confirm_update() -> bool:
    prompt = "DO YOU WANT TO UPDATE TRACKED NPM GLOBALS NOW?"
    if sys.stdin.isatty() and shutil.which("gum") is not None:
        argv = ["gum", "confirm"]
        colors = {
            "--selected.background": ml4w_color("primary"),
            "--selected.foreground": ml4w_color("onprimary"),
            "--prompt.foreground": ml4w_color("onsurface"),
        }
        for flag, value in colors.items():
            if value:
                argv.append(f"{flag}={value}")
        argv.append(prompt)
        return subprocess.run(argv, check=False).returncode == 0

    answer = input(f"{prompt} [y/N] ").strip().lower() if sys.stdin.isatty() else ""
    return answer in ("y", "yes")


def npm_terminal_update() -> None:
    data = npm_get_status(force_refresh=True)
    print("npm globals\n")
    for warning in (data.get("doctor") or {}).get("warnings") or []:
        print(f"! {warning}")
    if (data.get("doctor") or {}).get("needs_prefix_fix"):
        npm_bootstrap_for_mutation()
        clear_runtime_status()
        data = npm_get_status(force_refresh=True)

    targets = [item for item in data["packages"] if item["state"] in ("outdated", "missing")]
    if not targets:
        npm_refresh_waybar()
        print("Tracked npm globals are in sync.")
        if data["untracked"]:
            print("\nUntracked globals:")
            for item in data["untracked"]:
                print(f"{item['name']} {item['installed']}  adopt with: {item['adopt_command']}")
        if sys.stdin.isatty():
            input("\nPress Enter to close.")
        return

    outdated = [item for item in targets if item["state"] == "outdated"]
    missing = [item for item in targets if item["state"] == "missing"]
    if outdated:
        print(f"{len(outdated)} package{'s' if len(outdated) != 1 else ''} outdated:")
        for item in outdated:
            print(f"{item['name']} {item['installed']} -> {item['latest']}")
        print()
    if missing:
        print(f"{len(missing)} package{'s' if len(missing) != 1 else ''} missing:")
        for item in missing:
            print(f"{item['name']} latest {item.get('latest') or 'unknown'}")
        print()

    if not npm_confirm_update():
        print("\n:: Update canceled.")
        return

    for item in targets:
        npm_install_spec(item["spec"])
    clear_runtime_status()
    data = npm_get_status(force_refresh=True)
    npm_refresh_waybar()
    print()
    print_npm_summary(data)
    if sys.stdin.isatty():
        input("\nPress Enter to close.")


def cmd_npm(args) -> None:
    if args.npm_command in (None, "status"):
        data = npm_get_status()
        if getattr(args, "json", False):
            print(json.dumps(data, indent=2, sort_keys=True))
        else:
            print_npm_status(data)
        return

    if args.npm_command == "refresh":
        data = npm_get_status(force_refresh=True)
        npm_refresh_waybar()
        print_npm_status(data)
        return

    if args.npm_command == "doctor":
        data = npm_doctor_data()
        if args.fix and data.get("needs_prefix_fix"):
            npm_fix_prefix()
            data = npm_doctor_data()
        if args.json:
            print(json.dumps(data, indent=2, sort_keys=True))
            return
        print("npm doctor")
        print(f"  npm:             {'found' if data['npm_found'] else 'missing'}")
        print(f"  global prefix:   {data.get('prefix') or 'unknown'}")
        print(f"  expected prefix: {data['expected_prefix']}")
        print(f"  ~/.local/bin:    {'on PATH' if data['path_ok'] else 'missing from PATH'}")
        if data["warnings"]:
            for warning in data["warnings"]:
                print(f"  ! {warning}")
            if data.get("needs_prefix_fix"):
                print("  fix: dot npm doctor --fix")
        else:
            print("  ok")
        return

    if args.npm_command == "add":
        npm_spec_name(args.package)
        npm_install_spec(args.package)
        npm_rewrite_tracked_file(add_spec=args.package)
        clear_runtime_status()
        data = npm_get_status(force_refresh=True)
        npm_refresh_waybar()
        print_npm_status(data)
        return

    if args.npm_command == "update":
        if args.all:
            if args.package:
                raise SystemExit("use either `dot npm update --all` or `dot npm update <pkg>`")
            npm_update_all()
            return
        if not args.package:
            raise SystemExit("usage: dot npm update <pkg> or dot npm update --all")
        npm_install_tracked(args.package)
        return

    if args.npm_command == "remove":
        name = npm_spec_name(args.package)
        npm_bootstrap_for_mutation()
        run_checked(["npm", "uninstall", "-g", name])
        npm_rewrite_tracked_file(remove_pkg=args.package)
        clear_runtime_status()
        data = npm_get_status(force_refresh=True)
        npm_refresh_waybar()
        print_npm_status(data)
        return

    if args.npm_command == "waybar":
        print(json.dumps(npm_waybar_payload(npm_get_waybar_status()), separators=(",", ":")))
        return

    if args.npm_command == "terminal-update":
        npm_terminal_update()
        return

    raise SystemExit(f"unknown npm action: {args.npm_command}")


