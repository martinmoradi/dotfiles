# --- helpers ----------------------------------------------------------------

def sha256(path: Path) -> Optional[str]:
    try:
        h = hashlib.sha256()
        with open(path, "rb") as fh:
            for chunk in iter(lambda: fh.read(65536), b""):
                h.update(chunk)
        return h.hexdigest()
    except OSError:
        return None


def is_executable(path: Path) -> bool:
    return os.access(path, os.X_OK)


def make_executable(path: Path) -> None:
    st = os.stat(path)
    os.chmod(path, st.st_mode | 0o111)


def guard_skip_reason(g: Guard) -> Optional[str]:
    """Return a human reason if the step must be skipped, else None."""
    if g.repo_exists is not None and not g.repo_exists.exists():
        return f"missing in repo: {g.repo_exists.name}"
    if g.target_exists is not None and not g.target_exists.exists():
        return f"target absent: {g.target_exists}"
    if g.command is not None and shutil.which(g.command) is None:
        return f"command not found: {g.command}"
    if g.sudo_n and subprocess.run(
        ["sudo", "-n", "true"], check=False,
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    ).returncode != 0:
        return "no passwordless sudo"
    return None


def tree_diff(src: Path, dst: Path):
    """Return (changed, missing_in_target, extra_in_target) file counts."""
    def rel_files(root):
        out = {}
        for base, _dirs, files in os.walk(root):
            for f in files:
                p = Path(base) / f
                out[p.relative_to(root)] = p
        return out

    s = rel_files(src)
    d = rel_files(dst)
    changed = sum(1 for r, p in s.items() if r in d and sha256(p) != sha256(d[r]))
    missing = sum(1 for r in s if r not in d)
    extra = sum(1 for r in d if r not in s)
    return changed, missing, extra


# --- status -----------------------------------------------------------------

def step_status(step: Step) -> Status:
    reason = guard_skip_reason(step.guard)
    if reason:
        return Status(SKIPPED, reason)

    k = step.kind
    if k is Kind.BUTTON:
        if step.status_fn is not None:
            return step.status_fn()
        return Status(ACTION_ONLY, "press enter to run")
    if k is Kind.ACTION:
        return Status(ACTION_ONLY, "runs on deploy")
    if k is Kind.TOGGLE:
        mode = step.detect()
        return Status(ACTION_ONLY, (step.transitions.get(mode) or {}).get("desc", mode))
    if k is Kind.MKDIR:
        return Status(IN_SYNC if step.dst.exists() else NEW)

    if k is Kind.COPY:
        if step.src is None or not step.src.exists():
            return Status(SKIPPED, "missing source")
        if not step.dst.exists():
            return Status(NEW)
        if sha256(step.src) != sha256(step.dst):
            return Status(DRIFTED, "content")
        if step.executable and not is_executable(step.dst):
            return Status(DRIFTED, "mode")
        return Status(IN_SYNC)

    if k is Kind.DIR_SYNC:
        if not step.dst.exists():
            return Status(NEW)
        changed, missing, extra = tree_diff(step.src, step.dst)
        if changed or missing or extra:
            bits = []
            if changed:
                bits.append(f"{changed} changed")
            if missing:
                bits.append(f"{missing} new")
            if extra:
                bits.append(f"{extra} extra")
            return Status(DRIFTED, ", ".join(bits))
        return Status(IN_SYNC)

    if k is Kind.SYMLINK:
        if not step.dst.is_symlink():
            return Status(NEW if not step.dst.exists() else DRIFTED, "not a symlink")
        if os.readlink(step.dst) != str(step.src):
            return Status(DRIFTED, "wrong target")
        return Status(IN_SYNC)

    if k is Kind.GEN_IF_MISSING:
        if step.dst.exists() and step.dst.stat().st_size > 0:
            return Status(IN_SYNC, "user state")
        return Status(NEW)

    if k is Kind.LEGACY_RM:
        return Status(DRIFTED, "legacy, will remove") if step.dst.exists() else Status(IN_SYNC)

    return Status(SKIPPED, "unknown kind")


def step_display(step: Step) -> str:
    """Label to show. TOGGLE shows the action for the *current* live mode."""
    if step.display_fn is not None:
        return step.display_fn()
    if step.kind is Kind.TOGGLE:
        mode = step.detect()
        trans = step.transitions.get(mode) or step.transitions.get("unknown") or {}
        return trans.get("action", step.label)
    return step.label


def module_mode(module: Module) -> str:
    """Current TOGGLE mode description for a module, if it has one."""
    for s in module.steps:
        if s.kind is Kind.TOGGLE:
            st = step_status(s)
            return st.detail if st.state == ACTION_ONLY else ""
    return ""


def module_status(module: Module) -> Status:
    states = [step_status(s).state for s in module.steps]
    syncable = [s for s in states if s not in (ACTION_ONLY, SKIPPED)]
    if not syncable:
        return Status(ACTION_ONLY if ACTION_ONLY in states else SKIPPED)
    if DRIFTED in syncable:
        n = sum(1 for s in syncable if s == DRIFTED)
        return Status(DRIFTED, f"{n} drift")
    if NEW in syncable:
        return Status(NEW if all(s == NEW for s in syncable) else DRIFTED,
                      f"{sum(1 for s in syncable if s == NEW)} new")
    return Status(IN_SYNC)


# --- apply ------------------------------------------------------------------

def _mirror_dir(src: Path, dst: Path) -> None:
    """rsync -a --delete with a stdlib fallback. Delete pass is guarded."""
    dst.mkdir(parents=True, exist_ok=True)
    if shutil.which("rsync"):
        subprocess.run(["rsync", "-a", "--delete", f"{src}/", f"{dst}/"], check=True)
        return
    shutil.copytree(src, dst, dirs_exist_ok=True)
    # honour --delete: remove targets not present in source, but only under ~/.config
    base = (HOME / ".config").resolve()
    if base not in dst.resolve().parents and dst.resolve() != base:
        raise RuntimeError(f"refusing to prune outside ~/.config: {dst}")
    src_rel = {p.relative_to(src) for p in src.rglob("*") if p.is_file()}
    for p in sorted(dst.rglob("*"), reverse=True):
        rel = p.relative_to(dst)
        if p.is_file() and rel not in src_rel:
            p.unlink()
        elif p.is_dir() and not any(p.iterdir()):
            p.rmdir()


def apply_step(step: Step, dry_run: bool) -> str:
    """Run one step. Returns a short past-tense verb for reporting."""
    reason = guard_skip_reason(step.guard)
    if reason:
        if step.skip_hint:
            print(f"      ! {step.skip_hint}")
        return f"skipped ({reason})"

    st = step_status(step)
    k = step.kind

    if k is Kind.ACTION:
        if dry_run:
            return f"would run: {step.dry_note}"
        if step.run is not None:
            step.run()
            return "ran"
        rc = subprocess.run(step.run_argv, check=False).returncode
        return "ran" if rc == 0 else f"failed (rc={rc})"

    if k is Kind.MKDIR:
        if dry_run:
            return "ok" if st.state == IN_SYNC else "would create"
        step.dst.mkdir(parents=True, exist_ok=True)
        return "ok"

    if k is Kind.COPY:
        if st.state == SKIPPED:
            return f"skipped ({st.detail})"
        if dry_run:
            return "ok" if st.state == IN_SYNC else f"would copy ({st.state})"
        step.dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(step.src, step.dst)
        if step.executable:
            make_executable(step.dst)
        return "ok" if st.state == IN_SYNC else "copied"

    if k is Kind.DIR_SYNC:
        if dry_run:
            return "ok" if st.state == IN_SYNC else f"would sync ({st.detail or st.state})"
        _mirror_dir(step.src, step.dst)
        if step.exec_glob:
            for p in step.dst.glob(step.exec_glob):
                make_executable(p)
        return "ok" if st.state == IN_SYNC else "synced"

    if k is Kind.SYMLINK:
        if dry_run:
            return "ok" if st.state == IN_SYNC else f"would link ({st.state})"
        if step.executable and step.src.exists():
            make_executable(step.src)
        step.dst.parent.mkdir(parents=True, exist_ok=True)
        if step.dst.is_symlink() or step.dst.exists():
            step.dst.unlink()
        step.dst.symlink_to(step.src)
        return "ok" if st.state == IN_SYNC else "linked"

    if k is Kind.GEN_IF_MISSING:
        if st.state == IN_SYNC:
            return "ok"
        if dry_run:
            return "would generate"
        content = step.generator() if step.generator else ""
        if content:
            step.dst.parent.mkdir(parents=True, exist_ok=True)
            step.dst.write_text(content)
            return "generated"
        return "skipped (nothing to generate)"

    if k is Kind.LEGACY_RM:
        if st.state == IN_SYNC:
            return "ok"
        if dry_run:
            return "would remove"
        step.dst.unlink()
        return "removed"

    return "skipped (unknown)"


# --- colour -----------------------------------------------------------------

_COLOR = sys.stdout.isatty()
_CODES = {IN_SYNC: "32", DRIFTED: "33", NEW: "36", SKIPPED: "90", ACTION_ONLY: "35"}


def paint(text: str, code: str) -> str:
    return f"\033[{code}m{text}\033[0m" if _COLOR else text


def state_label(state: str) -> str:
    text = {IN_SYNC: "in sync", DRIFTED: "drift", NEW: "new",
            SKIPPED: "skip", ACTION_ONLY: "action"}[state]
    return paint(text, _CODES[state])


# --- commands ---------------------------------------------------------------

def select_modules(reg: List[Module], names) -> List[Module]:
    if not names:
        return reg
    wanted = set(names)
    chosen = [m for m in reg if m.name in wanted]
    missing = wanted - {m.name for m in chosen}
    if missing:
        raise SystemExit(f"unknown module(s): {', '.join(sorted(missing))}\n"
                         f"available: {', '.join(m.name for m in reg)}")
    return chosen


def deploy(reg: List[Module], names=None, step_filter=None, dry_run=False) -> None:
    modules = select_modules(reg, names)
    header = "Dry-run (no changes)" if dry_run else "Deploying"
    print(f"{header} from {REPO}\n")
    single = len(modules) == 1
    for m in modules:
        steps = [
            (idx, step) for idx, step in enumerate(m.steps)
            if not step.interactive_only and not (single and step_filter is not None and idx not in step_filter)
        ]
        if not steps:
            continue
        print(paint(m.name, "1"))
        for _idx, step in steps:
            result = apply_step(step, dry_run)
            print(f"   {step_display(step):<34} {result}")
        print()
    if not dry_run:
        print("Done. Reload hints: Super+Shift+R (shell), kill -SIGUSR1 $(pgrep kitty).")


def run_toggle(step: Step) -> None:
    """Run a TOGGLE's flip for the current live mode (TUI escape hatch)."""
    mode = step.detect()
    trans = step.transitions.get(mode) or step.transitions.get("unknown")
    if not trans:
        print("waybar: nothing to do")
        return
    print(f"waybar: {trans['action']}")
    rc = subprocess.run(trans["argv"], check=False).returncode
    print("done." if rc == 0 else f"failed (rc={rc})")


def run_button(step: Step) -> None:
    """Run an interactive BUTTON step."""
    print(f"{step.label}:")
    if step.run is not None:
        step.run()
        return
    if step.run_argv is not None:
        run_checked(step.run_argv)
        return
    print("nothing to do")


def cmd_status(reg: List[Module], module=None, verbose=False) -> None:
    modules = select_modules(reg, [module] if module else None)
    show_steps = verbose or module is not None
    counts = {IN_SYNC: 0, DRIFTED: 0, NEW: 0, SKIPPED: 0, ACTION_ONLY: 0}
    for m in modules:
        ms = module_status(m)
        counts[ms.state] = counts.get(ms.state, 0) + 1
        bits = [b for b in (ms.detail, f"mode: {module_mode(m)}" if module_mode(m) else "") if b]
        detail = f"  ({'; '.join(bits)})" if bits else ""
        print(f"  {state_label(ms.state):<18} {m.name:<16}{detail}")
        if show_steps:
            for step in m.steps:
                ss = step_status(step)
                sd = f"  {ss.detail}" if ss.detail else ""
                print(f"        {state_label(ss.state):<18} {step_display(step)}{sd}")
    print()
    summary = ", ".join(f"{n} {state_label(s)}" for s, n in counts.items() if n)
    print(f"  {summary}")


def cmd_diff(reg: List[Module], module=None) -> None:
    modules = select_modules(reg, [module] if module else None)
    for m in modules:
        for step in m.steps:
            if step.kind is Kind.COPY and step.src and step.src.exists() and step.dst.exists():
                a = step.src.read_text(errors="replace").splitlines(keepends=True)
                b = step.dst.read_text(errors="replace").splitlines(keepends=True)
                d = list(difflib.unified_diff(b, a, fromfile=f"live {step.dst}", tofile=f"repo {step.src}"))
                if d:
                    print(f"# {m.name} / {step.label}")
                    sys.stdout.writelines(d)
                    print()
            elif step.kind is Kind.DIR_SYNC and step.dst.exists():
                changed, missing, extra = tree_diff(step.src, step.dst)
                if changed or missing or extra:
                    print(f"# {m.name} / {step.label}: {changed} changed, {missing} new, {extra} extra\n")
            elif step.kind is Kind.TOGGLE:
                mode = step.detect()
                trans = step.transitions.get(mode) or {}
                print(f"# {m.name} / workspace mode: {trans.get('desc', mode)} "
                      f"-> flip would: {trans.get('action', '')}\n")
            elif step.kind is Kind.ACTION:
                print(f"# {m.name} / {step.label}: {step.dry_note}\n")
            elif step.kind is Kind.BUTTON:
                print(f"# {m.name} / {step.label}: {state_label_plain(step_status(step))}\n")


def cmd_snapshot(reg: List[Module]) -> None:
    print(f"Snapshotting machine state into {REPO}\n")
    for m in reg:
        for step in m.steps:
            if step.kind is Kind.COPY and step.snapshot and step.dst.exists():
                step.src.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(step.dst, step.src)
                print(f"   {step.src.relative_to(REPO)}")

    pkg = REPO / "packages"
    pkg.mkdir(exist_ok=True)
    if shutil.which("pacman"):
        for flag, name in (("-Qqe", "pacman-explicit.txt"), ("-Qqm", "aur.txt")):
            out = subprocess.run(["pacman", flag], check=False, text=True, capture_output=True).stdout
            (pkg / name).write_text(out)
            print(f"   packages/{name} ({out.count(chr(10))})")
    if shutil.which("code"):
        out = subprocess.run(["code", "--list-extensions"], check=False, text=True, capture_output=True).stdout
        (REPO / "vscode" / "extensions.txt").write_text(out)
        print(f"   vscode/extensions.txt ({out.count(chr(10))})")

    print("\nDone. Review with 'git diff' and commit.")


def cmd_sync(args) -> None:
    script = REPO / "scripts" / "dotfiles-sync.sh"
    os.execv(str(script), [str(script)] + list(args))


def cmd_codex(action: str) -> None:
    if action == "status":
        clear_runtime_status()
        patch = codex_gui_patch_status(auto_fetch=True)
        install = codex_gui_install_status()
        print("Codex")
        print(f"  patch source: {state_label_plain(patch)}")
        print(f"  install:      {state_label_plain(install)}")
        print(f"  local path:   {CODEX_GUI_PATCH_DIR}")
        return
    if action == "pull":
        codex_gui_pull_patch_source()
        return
    if action == "diff":
        codex_gui_patch_diff()
        return
    if action == "install":
        codex_gui_install_patched()
        return
    if action == "path":
        print(CODEX_GUI_PATCH_DIR)
        return
    raise SystemExit(f"unknown codex action: {action}")


# --- TUI --------------------------------------------------------------------

class App:
    """curses front-end. tabs (all + modules) over a checkbox list with drift."""

    MARK = {IN_SYNC: "=", DRIFTED: "~", NEW: "+", SKIPPED: "·", ACTION_ONLY: "*"}

    def __init__(self, stdscr, reg: List[Module]):
        self.scr = stdscr
        self.reg = reg
        self.tabs = ["all"] + [m.name for m in reg]
        self.tab = 0
        self.cursor = 0
        self.top = 0
        self.selected_modules = {m.name for m in reg}
        self.selected_steps = {
            m.name: {i for i, s in enumerate(m.steps) if not s.interactive_only}
            for m in reg
        }
        self.request = None
        self.background_jobs = {}
        self.message = ""
        self.refresh_status()
        self._init_colors()

    def _init_colors(self):
        self.colors = {}
        if not curses.has_colors():
            return
        curses.start_color()
        curses.use_default_colors()
        pairs = {IN_SYNC: curses.COLOR_GREEN, DRIFTED: curses.COLOR_YELLOW,
                 NEW: curses.COLOR_CYAN, ACTION_ONLY: curses.COLOR_MAGENTA}
        for i, (state, col) in enumerate(pairs.items(), start=1):
            curses.init_pair(i, col, -1)
            self.colors[state] = curses.color_pair(i)
        self.colors[SKIPPED] = curses.A_DIM

    def attr(self, state):
        return self.colors.get(state, 0)

    def refresh_status(self):
        if self.has_background_jobs():
            self.message = "Background action still running; status refresh will follow."
            return
        global _codex_gui_auto_fetch_status
        clear_runtime_status()
        old_auto_fetch = _codex_gui_auto_fetch_status
        _codex_gui_auto_fetch_status = True
        try:
            self.mod_status = {m.name: module_status(m) for m in self.reg}
            self.step_status = {m.name: [step_status(s) for s in m.steps] for m in self.reg}
        finally:
            _codex_gui_auto_fetch_status = old_auto_fetch

    # current-context helpers -------------------------------------------------
    def is_all(self):
        return self.tab == 0

    def cur_module(self):
        return self.reg[self.tab - 1]

    def rows(self):
        if self.is_all():
            return [(m.name, self.mod_status[m.name], None) for m in self.reg]
        m = self.cur_module()
        return [(step_display(s), self.step_status[m.name][i], s) for i, s in enumerate(m.steps)]

    def is_checked(self, i):
        if self.is_all():
            return self.reg[i].name in self.selected_modules
        return i in self.selected_steps[self.cur_module().name]

    def toggle(self, i):
        if self.is_all():
            self.selected_modules ^= {self.reg[i].name}
        else:
            m = self.cur_module()
            if m.steps[i].interactive_only:   # toggles are buttons, not checkboxes
                return
            self.selected_steps[m.name] ^= {i}

    def toggle_all(self):
        if self.is_all():
            allnames = {m.name for m in self.reg}
            self.selected_modules = set() if self.selected_modules == allnames else allnames
        else:
            m = self.cur_module()
            full = {i for i, s in enumerate(m.steps) if not s.interactive_only}
            self.selected_steps[m.name] = set() if self.selected_steps[m.name] == full else full

    def count_selected(self):
        if self.is_all():
            return len(self.selected_modules)
        return len(self.selected_steps[self.cur_module().name])

    def has_background_jobs(self):
        return bool(self.background_jobs)

    def start_background_button(self, module: Module, idx: int):
        step = module.steps[idx]
        key = (module.name, idx)
        if key in self.background_jobs:
            self.message = f"{step_display(step)} is already running."
            return

        action = step.tui_run or step.run
        if action is None:
            self.message = f"{step_display(step)} has nothing to run."
            return

        label = step_display(step)
        results = queue.Queue(maxsize=1)

        def worker():
            try:
                action()
            except SystemExit as exc:
                if exc.code in (None, 0):
                    results.put((True, "done"))
                else:
                    results.put((False, str(exc.code)))
            except Exception as exc:
                results.put((False, str(exc) or exc.__class__.__name__))
            else:
                results.put((True, "done"))

        thread = threading.Thread(target=worker, daemon=True)
        self.background_jobs[key] = BackgroundJob(label, thread, results)
        self.message = f"{label}: running..."
        thread.start()

    def poll_background_jobs(self):
        finished = []
        for key, job in list(self.background_jobs.items()):
            if job.thread.is_alive():
                continue
            ok, detail = job.results.get() if not job.results.empty() else (False, "no result")
            finished.append((key, job.label, ok, detail))

        for key, _label, _ok, _detail in finished:
            self.background_jobs.pop(key, None)

        if not finished:
            return

        self.refresh_status()
        label = finished[-1][1]
        ok = finished[-1][2]
        detail = finished[-1][3]
        self.message = f"{label}: {'done' if ok else 'failed'}"
        if detail and detail != "done":
            self.message += f" ({detail})"

    # render ------------------------------------------------------------------
    def addnstr(self, y, x, s, attr=0):
        h, w = self.scr.getmaxyx()
        if 0 <= y < h and 0 <= x < w:
            try:
                self.scr.addnstr(y, x, s, max(0, w - x - 1), attr)
            except curses.error:
                pass

    def draw(self):
        self.scr.erase()
        h, w = self.scr.getmaxyx()
        self.addnstr(0, 0, "dot   repo ↔ live machine", curses.A_BOLD)

        x = 0
        for i, t in enumerate(self.tabs):
            seg = f" {t} "
            self.addnstr(1, x, seg, curses.A_REVERSE if i == self.tab else curses.A_DIM)
            x += len(seg) + 1
        self.addnstr(2, 0, "─" * (w - 1))

        rows = self.rows()
        view_h = h - 5
        if self.cursor < self.top:
            self.top = self.cursor
        elif self.cursor >= self.top + view_h:
            self.top = self.cursor - view_h + 1

        for vi in range(view_h):
            ri = self.top + vi
            if ri >= len(rows):
                break
            label, status, step = rows[ri]
            is_toggle = step is not None and step.kind is Kind.TOGGLE
            is_button = step is not None and step.kind is Kind.BUTTON
            is_running = (not self.is_all()) and (self.cur_module().name, ri) in self.background_jobs
            row_attr = curses.A_REVERSE if ri == self.cursor else 0
            if is_toggle or is_button:
                # An action button, not a checkbox: arrow + action text, with
                # status on the right so it cannot read as a deploy checkbox.
                self.addnstr(3 + vi, 0, f" →  {label}".ljust(w - 1), row_attr)
                if is_running:
                    tail = "running..."
                else:
                    tail = f"now: {status.detail}" if is_toggle else state_label_plain(status)
                self.addnstr(3 + vi, max(0, w - len(tail) - 2), tail,
                             row_attr or self.attr(status.state))
            else:
                box = "[x]" if self.is_checked(ri) else "[ ]"
                mark = self.MARK.get(status.state, "?")
                self.addnstr(3 + vi, 0, f" {box} {mark} {label}".ljust(w - 1), row_attr)
                if not row_attr:
                    self.addnstr(3 + vi, 5, mark, self.attr(status.state))
                tail = state_label_plain(status)
                self.addnstr(3 + vi, max(0, w - len(tail) - 2), tail,
                             row_attr or self.attr(status.state))

        cur = rows[self.cursor] if self.cursor < len(rows) else None
        on_action = cur is not None and cur[2] is not None and cur[2].kind in (Kind.TOGGLE, Kind.BUTTON)
        enter = "enter run action" if on_action else f"enter deploy ({self.count_selected()})"
        if self.message:
            self.addnstr(h - 2, 0, self.message, curses.A_DIM)
        self.addnstr(h - 1, 0,
                     f" ↑↓ move  space toggle  ←→ context  a all/none  "
                     f"{enter}  r refresh  q quit",
                     curses.A_DIM)
        self.scr.refresh()

    def handle(self, k):
        rows = self.rows()
        if k in (curses.KEY_DOWN, ord("j")):
            self.cursor = min(len(rows) - 1, self.cursor + 1)
        elif k in (curses.KEY_UP, ord("k")):
            self.cursor = max(0, self.cursor - 1)
        elif k in (curses.KEY_RIGHT, ord("l")):
            self.tab = (self.tab + 1) % len(self.tabs)
            self.cursor = self.top = 0
        elif k in (curses.KEY_LEFT, ord("h")):
            self.tab = (self.tab - 1) % len(self.tabs)
            self.cursor = self.top = 0
        elif k == ord(" "):
            if rows:
                self.toggle(self.cursor)
        elif k == ord("a"):
            self.toggle_all()
        elif k == ord("r"):
            self.refresh_status()
        elif k in (curses.KEY_ENTER, 10, 13):
            if self.has_background_jobs():
                self.message = "Background action still running; wait for it to finish."
                return True
            if not self.is_all():
                m = self.cur_module()
                if self.cursor < len(m.steps) and m.steps[self.cursor].kind in (Kind.TOGGLE, Kind.BUTTON):
                    step = m.steps[self.cursor]
                    if step.kind is Kind.BUTTON and step.tui_background:
                        self.start_background_button(m, self.cursor)
                        return True
                    request = "toggle" if step.kind is Kind.TOGGLE else "button"
                    self.request = (request, m.name, self.cursor)
                    return False
            self._build_request()
            return False
        elif k in (ord("q"), 27):
            if self.has_background_jobs():
                self.message = "Background action still running; wait for it to finish."
                return True
            return False
        return True

    def _build_request(self):
        if self.is_all():
            names = [m.name for m in self.reg if m.name in self.selected_modules]
            if names:
                self.request = ("deploy", names, None)
        else:
            m = self.cur_module()
            sel = {i for i in self.selected_steps[m.name] if not m.steps[i].interactive_only}
            self.request = ("deploy", [m.name], sel)

    def run(self):
        curses.curs_set(0)
        self.scr.keypad(True)
        self.scr.timeout(250)
        while True:
            self.poll_background_jobs()
            self.draw()
            k = self.scr.getch()
            if k == -1:
                continue
            if not self.handle(k):
                break
        return self.request


def state_label_plain(status: Status) -> str:
    text = {IN_SYNC: "in sync", DRIFTED: "drift", NEW: "new",
            SKIPPED: "skip", ACTION_ONLY: "action"}[status.state]
    return f"{text} {status.detail}".strip() if status.detail else text


def run_tui(reg: List[Module]) -> None:
    if not (sys.stdout.isatty() and sys.stdin.isatty()):
        print("dot: interactive TUI needs a terminal. Use `dot status` or `dot deploy`.")
        return
    try:
        request = curses.wrapper(lambda scr: App(scr, reg).run())
    except curses.error as exc:
        raise SystemExit(f"dot: terminal too small or curses error: {exc}")
    if not request:
        return
    print()
    if request[0] == "deploy":
        _, names, step_filter = request
        deploy(reg, names=names, step_filter=step_filter, dry_run=False)
    elif request[0] == "toggle":
        _, modname, idx = request
        module = next(m for m in reg if m.name == modname)
        run_toggle(module.steps[idx])
    elif request[0] == "button":
        _, modname, idx = request
        module = next(m for m in reg if m.name == modname)
        run_button(module.steps[idx])


# --- entrypoint -------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="dot", description="dotfiles front door")
    sub = parser.add_subparsers(dest="command")

    p_deploy = sub.add_parser("deploy", help="apply repo state to the machine")
    p_deploy.add_argument("modules", nargs="*", help="modules to deploy (default: all)")
    p_deploy.add_argument("--dry-run", action="store_true", help="show changes, touch nothing")

    p_status = sub.add_parser("status", help="show per-module drift")
    p_status.add_argument("module", nargs="?", help="limit to one module (shows steps)")
    p_status.add_argument("-v", "--verbose", action="store_true", help="show every step")

    p_diff = sub.add_parser("diff", help="show repo-vs-live diffs")
    p_diff.add_argument("module", nargs="?", help="limit to one module")

    sub.add_parser("snapshot", help="capture machine drift back into the repo")

    p_sync = sub.add_parser("sync", help="snapshot + commit + push (dotfiles-sync)")
    p_sync.add_argument("args", nargs=argparse.REMAINDER, help="passed to dotfiles-sync")

    p_codex = sub.add_parser("codex", help="manage Codex patch source and patched GUI builds")
    p_codex.add_argument(
        "action",
        nargs="?",
        default="status",
        choices=("status", "pull", "diff", "install", "path"),
        help="status, pull gist updates, show pending diff, or patch + install",
    )

    p_npm = sub.add_parser("npm", help="manage tracked npm global packages")
    npm_sub = p_npm.add_subparsers(dest="npm_command")

    p_npm_status = npm_sub.add_parser("status", help="show tracked npm global status")
    p_npm_status.add_argument("--json", action="store_true", help="emit machine-readable status")

    npm_sub.add_parser("refresh", help="refresh registry status cache")

    p_npm_doctor = npm_sub.add_parser("doctor", help="check npm global prefix setup")
    p_npm_doctor.add_argument("--fix", action="store_true", help="set npm prefix to ~/.local when needed")
    p_npm_doctor.add_argument("--json", action="store_true", help="emit machine-readable doctor status")

    p_npm_add = npm_sub.add_parser("add", help="install a global package and track it")
    p_npm_add.add_argument("package", help="npm package spec, for example wrangler@latest")

    p_npm_update = npm_sub.add_parser("update", help="update tracked global package(s)")
    p_npm_update.add_argument("package", nargs="?", help="tracked package name or spec")
    p_npm_update.add_argument("--all", action="store_true", help="update all tracked outdated/missing packages")

    p_npm_remove = npm_sub.add_parser("remove", help="uninstall a global package and untrack it")
    p_npm_remove.add_argument("package", help="tracked package name or spec")

    npm_sub.add_parser("waybar", help="emit cached Waybar JSON")
    npm_sub.add_parser("terminal-update", help="terminal confirmation flow for Waybar click")

    return parser


def main() -> None:
    reg = build_registry()
    args = build_parser().parse_args()

    if args.command is None:
        run_tui(reg)
    elif args.command == "deploy":
        deploy(reg, names=args.modules, dry_run=args.dry_run)
    elif args.command == "status":
        cmd_status(reg, module=args.module, verbose=args.verbose)
    elif args.command == "diff":
        cmd_diff(reg, module=args.module)
    elif args.command == "snapshot":
        cmd_snapshot(reg)
    elif args.command == "sync":
        cmd_sync(args.args)
    elif args.command == "codex":
        cmd_codex(args.action)
    elif args.command == "npm":
        cmd_npm(args)


if __name__ == "__main__":
    try:
        main()
    except BrokenPipeError:
        sys.exit(0)
    except KeyboardInterrupt:
        sys.exit(130)
