def detect_waybar_mode() -> str:
    """split = my config (split-monitor-workspaces); vanilla = plugin disabled."""
    try:
        data = json.loads((CFG / "waybar/modules.json").read_text())
    except (OSError, ValueError):
        return "unknown"
    on_scroll = data.get("hyprland/workspaces", {}).get("on-scroll-up", "")
    if "split-cycleworkspaces" in on_scroll:
        return "split"
    if "workspace" in on_scroll:
        return "vanilla"
    return "unknown"


_codex_gui_auto_fetch_status = False
_codex_gui_patch_status: Optional[Status] = None
_npm_runtime_status: Optional[dict] = None


def clear_runtime_status() -> None:
    global _codex_gui_patch_status, _npm_runtime_status
    _codex_gui_patch_status = None
    _npm_runtime_status = None


def run_checked(argv: List[str], cwd: Optional[Path] = None) -> None:
    where = f"  ({cwd})" if cwd else ""
    print(f"+ {shlex.join(str(a) for a in argv)}{where}")
    rc = subprocess.run([str(a) for a in argv], cwd=cwd, check=False).returncode
    if rc != 0:
        raise SystemExit(rc)


def run_text(
    argv: List[str],
    cwd: Optional[Path] = None,
    timeout: Optional[int] = None,
) -> subprocess.CompletedProcess:
    return subprocess.run(
        [str(a) for a in argv],
        cwd=cwd,
        check=False,
        text=True,
        capture_output=True,
        timeout=timeout,
    )


def command_error(result: subprocess.CompletedProcess) -> str:
    lines = (result.stderr or result.stdout or "").strip().splitlines()
    return lines[-1] if lines else f"rc={result.returncode}"


def run_checked_quiet(argv: List[str], cwd: Optional[Path] = None) -> None:
    result = run_text(argv, cwd)
    if result.returncode != 0:
        raise RuntimeError(f"{shlex.join(str(a) for a in argv)} failed: {command_error(result)}")


def short_ref(ref: str) -> str:
    return ref[:8] if ref else "unknown"


def codex_gui_patch_repo_present() -> bool:
    return (CODEX_GUI_PATCH_DIR / ".git").exists()


def codex_gui_ensure_patch_repo(auto_fetch: bool) -> tuple[bool, str]:
    if shutil.which("git") is None:
        return False, "command not found: git"

    if not codex_gui_patch_repo_present():
        if CODEX_GUI_PATCH_DIR.exists():
            return False, f"path exists but is not a git repo: {CODEX_GUI_PATCH_DIR}"
        if not auto_fetch:
            return False, "patch source not cloned"
        CODEX_GUI_PATCH_DIR.parent.mkdir(parents=True, exist_ok=True)
        result = run_text(["git", "clone", CODEX_GUI_PATCH_REPO_URL, str(CODEX_GUI_PATCH_DIR)])
        if result.returncode != 0:
            return False, f"clone failed: {command_error(result)}"
        return True, ""

    if auto_fetch:
        result = run_text(["git", "fetch", "--prune", "origin", CODEX_GUI_PATCH_BRANCH], CODEX_GUI_PATCH_DIR)
        if result.returncode != 0:
            return False, f"fetch failed: {command_error(result)}"

    return True, ""


def codex_gui_git_stdout(args: List[str]) -> tuple[bool, str]:
    result = run_text(["git", *args], CODEX_GUI_PATCH_DIR)
    if result.returncode != 0:
        return False, command_error(result)
    return True, result.stdout.strip()


def codex_gui_patch_refs() -> tuple[str, str, int, int]:
    ok, local = codex_gui_git_stdout(["rev-parse", "HEAD"])
    if not ok:
        raise RuntimeError(local)
    ok, remote = codex_gui_git_stdout(["rev-parse", f"origin/{CODEX_GUI_PATCH_BRANCH}"])
    if not ok:
        remote = local
    result = run_text(
        ["git", "rev-list", "--left-right", "--count", f"HEAD...origin/{CODEX_GUI_PATCH_BRANCH}"],
        CODEX_GUI_PATCH_DIR,
    )
    if result.returncode != 0:
        return local, remote, 0, 0
    parts = result.stdout.split()
    ahead, behind = (int(parts[0]), int(parts[1])) if len(parts) >= 2 else (0, 0)
    return local, remote, ahead, behind


def codex_gui_patch_status(auto_fetch: Optional[bool] = None) -> Status:
    global _codex_gui_patch_status
    if auto_fetch is None:
        auto_fetch = _codex_gui_auto_fetch_status
    if _codex_gui_patch_status is not None:
        return _codex_gui_patch_status

    ok, reason = codex_gui_ensure_patch_repo(auto_fetch=auto_fetch)
    if not ok:
        state = NEW if reason == "patch source not cloned" else SKIPPED
        status = Status(state, reason)
        if auto_fetch:
            _codex_gui_patch_status = status
        return status

    if not CODEX_GUI_PATCH_FILE.exists():
        status = Status(SKIPPED, "missing codex-app-unofficial.patch")
        if auto_fetch:
            _codex_gui_patch_status = status
        return status

    dirty = run_text(["git", "status", "--porcelain"], CODEX_GUI_PATCH_DIR)
    if dirty.returncode == 0 and dirty.stdout.strip():
        status = Status(DRIFTED, f"local edits in {CODEX_GUI_PATCH_DIR}")
        if auto_fetch:
            _codex_gui_patch_status = status
        return status

    try:
        local, remote, ahead, behind = codex_gui_patch_refs()
    except RuntimeError as exc:
        status = Status(SKIPPED, str(exc))
        if auto_fetch:
            _codex_gui_patch_status = status
        return status

    if ahead and behind:
        status = Status(DRIFTED, f"diverged +{ahead}/-{behind}: {short_ref(local)} vs {short_ref(remote)}")
    elif behind:
        status = Status(DRIFTED, f"behind {behind}: {short_ref(local)} -> {short_ref(remote)}")
    elif ahead:
        status = Status(DRIFTED, f"local ahead {ahead}: {short_ref(local)}")
    else:
        status = Status(IN_SYNC, short_ref(local))

    if auto_fetch:
        _codex_gui_patch_status = status
    return status


def codex_gui_patch_display() -> str:
    status = codex_gui_patch_status()
    if status.state == NEW:
        return "clone patch source"
    if status.state == DRIFTED:
        return "pull patch source"
    if status.state == SKIPPED:
        return "check patch source"
    return "fetch patch source"


def codex_gui_patch_rev() -> str:
    if not codex_gui_patch_repo_present():
        return "not cloned"
    ok, local = codex_gui_git_stdout(["rev-parse", "--short=8", "HEAD"])
    return local if ok else "unknown"


def codex_gui_pull_patch_source(quiet: bool = False) -> None:
    clear_runtime_status()
    if shutil.which("git") is None:
        raise SystemExit("git is required")

    run = run_checked_quiet if quiet else run_checked
    if not codex_gui_patch_repo_present():
        if CODEX_GUI_PATCH_DIR.exists():
            raise SystemExit(f"{CODEX_GUI_PATCH_DIR} exists but is not a git repo")
        CODEX_GUI_PATCH_DIR.parent.mkdir(parents=True, exist_ok=True)
        run(["git", "clone", CODEX_GUI_PATCH_REPO_URL, str(CODEX_GUI_PATCH_DIR)])
    else:
        dirty = run_text(["git", "status", "--porcelain"], CODEX_GUI_PATCH_DIR)
        if dirty.returncode == 0 and dirty.stdout.strip():
            if quiet:
                raise RuntimeError(f"patch source has local edits: {CODEX_GUI_PATCH_DIR}")
            print(f"Patch source has local edits: {CODEX_GUI_PATCH_DIR}")
            print(dirty.stdout.rstrip())
            raise SystemExit(1)
        run(["git", "fetch", "--prune", "origin", CODEX_GUI_PATCH_BRANCH], CODEX_GUI_PATCH_DIR)
        run(["git", "pull", "--ff-only", "origin", CODEX_GUI_PATCH_BRANCH], CODEX_GUI_PATCH_DIR)

    clear_runtime_status()
    status = codex_gui_patch_status(auto_fetch=False)
    if not quiet:
        print(f"patch source: {state_label_plain(status)}")
        print(f"path: {CODEX_GUI_PATCH_DIR}")


def codex_gui_pull_patch_source_quiet() -> None:
    codex_gui_pull_patch_source(quiet=True)


def codex_gui_patch_diff() -> None:
    clear_runtime_status()
    ok, reason = codex_gui_ensure_patch_repo(auto_fetch=True)
    if not ok:
        raise SystemExit(reason)

    status = codex_gui_patch_status(auto_fetch=False)
    print(f"patch source: {state_label_plain(status)}")
    print(f"path: {CODEX_GUI_PATCH_DIR}\n")

    local, remote, _ahead, behind = codex_gui_patch_refs()
    if local == remote:
        print("Patch source is in sync with origin/main.")
        return

    if behind:
        run_checked(["git", "log", "--oneline", f"HEAD..origin/{CODEX_GUI_PATCH_BRANCH}"], CODEX_GUI_PATCH_DIR)
        print()
    run_checked(["git", "diff", "--stat", f"HEAD..origin/{CODEX_GUI_PATCH_BRANCH}"], CODEX_GUI_PATCH_DIR)
    print()
    run_checked(["git", "diff", f"HEAD..origin/{CODEX_GUI_PATCH_BRANCH}"], CODEX_GUI_PATCH_DIR)


def codex_gui_patch_file_from_diff(patch_path: Path, rel_path: str) -> str:
    current_file = False
    in_hunk = False
    out: list[str] = []
    diff_header = f"diff --git a/{rel_path} b/{rel_path}"

    for line in patch_path.read_text().splitlines(keepends=True):
        if line.startswith("diff --git "):
            if current_file:
                break
            current_file = line.rstrip("\n") == diff_header
            in_hunk = False
            continue
        if not current_file:
            continue
        if line.startswith("@@"):
            in_hunk = True
            continue
        if not in_hunk or line.startswith("\\"):
            continue
        if line.startswith("+"):
            out.append(line[1:])
        elif line.startswith(" "):
            out.append(line[1:])

    if not out:
        raise RuntimeError(f"could not extract {rel_path} from {patch_path}")
    return "".join(out)


def pkgbuild_quote(value: str) -> str:
    return "'" + value.replace("'", "'\\''") + "'"


def codex_gui_ensure_pkgbuild_array_value(text: str, name: str, value: str) -> str:
    quoted = pkgbuild_quote(value)
    multiline = re.search(rf"(?ms)^(?P<head>{name}=\(\n)(?P<body>.*?)(?P<tail>^\))", text)
    if multiline:
        if value in multiline.group("body"):
            return text
        return text[:multiline.end("body")] + f"  {quoted}\n" + text[multiline.end("body"):]

    singleline = re.search(rf"(?m)^(?P<head>{name}=\()(?P<body>[^\n]*)(?P<tail>\))", text)
    if singleline:
        if value in singleline.group("body"):
            return text
        body = singleline.group("body").rstrip()
        return text[:singleline.start("body")] + body + (" " if body else "") + quoted + text[singleline.end("body"):]

    raise RuntimeError(f"could not find {name}=() in PKGBUILD")


def codex_gui_ensure_pkgbuild_makedepend(text: str) -> str:
    if re.search(r"(?m)^makedepends=\(", text):
        return codex_gui_ensure_pkgbuild_array_value(text, "makedepends", "asar")

    line = "makedepends=('asar')\n"
    license_line = re.search(r"(?m)^license=.*\n", text)
    if license_line:
        return text[:license_line.end()] + line + text[license_line.end():]

    depends_line = re.search(r"(?m)^depends=.*\n", text)
    if depends_line:
        return text[:depends_line.start()] + line + text[depends_line.start():]

    raise RuntimeError("could not place makedepends in PKGBUILD")


def codex_gui_ensure_pkgbuild_prepare(text: str) -> str:
    command = f'  node "${{srcdir}}/{CODEX_GUI_PATCH_PAYLOAD}" "${{srcdir}}/linux-unpacked/resources/app.asar"\n'
    if command.strip() in text:
        return text

    prepare_fn = re.search(r"(?m)^prepare\(\)\s*\{\n", text)
    if prepare_fn:
        return text[:prepare_fn.end()] + command + text[prepare_fn.end():]

    package_fn = re.search(r"(?m)^package\(\)\s*\{", text)
    if not package_fn:
        raise RuntimeError("could not find package() in PKGBUILD")

    block = f"prepare() {{\n{command}}}\n\n"
    return text[:package_fn.start()] + block + text[package_fn.start():]


def codex_gui_apply_patch_adaptively(aur_dir: Path) -> None:
    payload = codex_gui_patch_file_from_diff(CODEX_GUI_PATCH_FILE, CODEX_GUI_PATCH_PAYLOAD)
    payload_path = aur_dir / CODEX_GUI_PATCH_PAYLOAD
    payload_path.write_text(payload)
    payload_hash = hashlib.sha256(payload.encode()).hexdigest()

    pkgbuild_path = aur_dir / "PKGBUILD"
    pkgbuild = pkgbuild_path.read_text()
    pkgbuild = codex_gui_ensure_pkgbuild_makedepend(pkgbuild)
    pkgbuild = codex_gui_ensure_pkgbuild_array_value(pkgbuild, "source", CODEX_GUI_PATCH_PAYLOAD)
    pkgbuild = codex_gui_ensure_pkgbuild_array_value(pkgbuild, "sha256sums", payload_hash)
    pkgbuild = codex_gui_ensure_pkgbuild_prepare(pkgbuild)
    pkgbuild_path.write_text(pkgbuild)

    srcinfo = run_text(["makepkg", "--printsrcinfo"], aur_dir)
    if srcinfo.returncode != 0:
        raise RuntimeError(f"makepkg --printsrcinfo failed: {command_error(srcinfo)}")
    (aur_dir / ".SRCINFO").write_text(srcinfo.stdout)

    print(f"Adaptive patch added {CODEX_GUI_PATCH_PAYLOAD} ({short_ref(payload_hash)}) to the current AUR package.")


def codex_gui_apply_patch(aur_dir: Path) -> None:
    check = run_text(["git", "apply", "--check", "--whitespace=nowarn", str(CODEX_GUI_PATCH_FILE)], aur_dir)
    if check.returncode == 0:
        run_checked(["git", "apply", "--whitespace=nowarn", str(CODEX_GUI_PATCH_FILE)], aur_dir)
        return

    print("Exact gist patch does not match the current AUR package.")
    print(f"git apply --check: {command_error(check)}")
    print("Warning: adapting the pulled gist patch to current AUR metadata.")
    print("If upstream Codex internals changed, the package build may still fail; reinstalling the unpatched package is the fallback.")
    codex_gui_apply_patch_adaptively(aur_dir)


def codex_gui_installed_version() -> tuple[bool, str]:
    if shutil.which("pacman") is None:
        return False, "pacman not found"
    result = run_text(["pacman", "-Q", CODEX_GUI_PACKAGE])
    if result.returncode != 0:
        return False, "not installed"
    return True, result.stdout.strip()


def codex_gui_install_status() -> Status:
    patch_status = codex_gui_patch_status()
    if patch_status.state in (SKIPPED, NEW):
        return Status(patch_status.state, f"patch source: {patch_status.detail}")

    installed, detail = codex_gui_installed_version()
    if not installed:
        return Status(NEW, f"{detail}; patch {codex_gui_patch_rev()}")
    return Status(ACTION_ONLY, f"{detail}; patch {codex_gui_patch_rev()}")


def codex_gui_install_patched() -> None:
    clear_runtime_status()
    ok, reason = codex_gui_ensure_patch_repo(auto_fetch=True)
    if not ok:
        raise SystemExit(reason)
    patch_status = codex_gui_patch_status(auto_fetch=False)
    if patch_status.state == DRIFTED:
        print(f"Using local patch source even though it is {patch_status.detail}.")
        print("Run `dot codex pull` first if you want the latest gist revision.\n")

    for cmd in ("git", "makepkg"):
        if shutil.which(cmd) is None:
            raise SystemExit(f"{cmd} is required")
    if not CODEX_GUI_PATCH_FILE.exists():
        raise SystemExit(f"missing patch file: {CODEX_GUI_PATCH_FILE}")

    CACHE.mkdir(parents=True, exist_ok=True)
    build_root = Path(tempfile.mkdtemp(prefix="codex-gui-", dir=CACHE))
    aur_dir = build_root / CODEX_GUI_PACKAGE
    try:
        run_checked(["git", "clone", "--depth=1", CODEX_GUI_AUR_URL, str(aur_dir)])
        codex_gui_apply_patch(aur_dir)
        run_checked(["makepkg", "-si"], aur_dir)
    except SystemExit:
        print(f"\nBuild workspace kept for inspection: {build_root}")
        raise
    shutil.rmtree(build_root, ignore_errors=True)
    print("Patched Codex GUI install complete.")


# --- npm globals ------------------------------------------------------------

def npm_have_command() -> bool:
    return shutil.which("npm") is not None


def npm_strip_comment(line: str) -> str:
    """Strip full-line and whitespace-prefixed trailing comments."""
    for index, ch in enumerate(line):
        if ch == "#" and (index == 0 or line[index - 1].isspace()):
            return line[:index].strip()
    return line.strip()


def npm_spec_name(spec: str) -> str:
    spec = spec.strip()
    if not spec:
        raise ValueError("empty package spec")
    if spec.startswith("-") or any(ch.isspace() for ch in spec):
        raise ValueError(f"unsupported package spec: {spec}")
    if spec.startswith("@"):
        slash = spec.find("/")
        if slash <= 1:
            raise ValueError(f"scoped package needs a name: {spec}")
        at = spec.rfind("@")
        return spec[:at] if at > slash else spec
    return spec.split("@", 1)[0]


def npm_parse_tracked_specs() -> tuple[list[dict], list[str]]:
    warnings = []
    if not NPM_GLOBALS_FILE.exists():
        return [], [f"tracked file missing: {NPM_GLOBALS_FILE.relative_to(REPO)}"]

    specs = []
    seen_names = set()
    for line_no, line in enumerate(NPM_GLOBALS_FILE.read_text().splitlines(), start=1):
        spec = npm_strip_comment(line)
        if not spec:
            continue
        try:
            name = npm_spec_name(spec)
        except ValueError as exc:
            warnings.append(f"line {line_no}: {exc}")
            continue
        if name in seen_names:
            warnings.append(f"line {line_no}: duplicate tracked package ignored: {name}")
            continue
        seen_names.add(name)
        specs.append({"name": name, "spec": spec, "line": line_no})
    return specs, warnings


def npm_find_tracked(pkg: str, specs: Optional[list[dict]] = None) -> dict:
    specs = specs if specs is not None else npm_parse_tracked_specs()[0]
    try:
        wanted_name = npm_spec_name(pkg)
    except ValueError:
        wanted_name = pkg
    matches = [item for item in specs if item["name"] == wanted_name or item["spec"] == pkg]
    if not matches:
        raise SystemExit(f"{pkg} is not tracked in {NPM_GLOBALS_FILE.relative_to(REPO)}")
    return matches[0]


def npm_ensure_globals_file() -> None:
    if NPM_GLOBALS_FILE.exists():
        return
    NPM_GLOBALS_FILE.parent.mkdir(parents=True, exist_ok=True)
    NPM_GLOBALS_FILE.write_text(
        "# Tracked npm globals. One package spec per line.\n"
        "# Blank lines and comments are ignored.\n\n"
    )


def npm_rewrite_tracked_file(add_spec: Optional[str] = None, remove_pkg: Optional[str] = None) -> None:
    npm_ensure_globals_file()
    lines = NPM_GLOBALS_FILE.read_text().splitlines()

    add_name = npm_spec_name(add_spec) if add_spec else None
    remove_name = npm_spec_name(remove_pkg) if remove_pkg else None
    replaced = False
    changed = False
    out = []

    for line in lines:
        active = npm_strip_comment(line)
        if not active:
            out.append(line)
            continue
        try:
            name = npm_spec_name(active)
        except ValueError:
            out.append(line)
            continue
        if remove_name and (name == remove_name or active == remove_pkg):
            changed = True
            continue
        if add_name and name == add_name:
            if not replaced:
                out.append(add_spec)
                replaced = True
            changed = True
            continue
        out.append(line)

    if add_spec and not replaced:
        if out and out[-1].strip():
            out.append("")
        out.append(add_spec)
        changed = True

    if changed:
        NPM_GLOBALS_FILE.write_text("\n".join(out).rstrip() + "\n")


def npm_doctor_data() -> dict:
    expected = str(NPM_EXPECTED_PREFIX)
    data = {
        "npm_found": npm_have_command(),
        "prefix": None,
        "expected_prefix": expected,
        "prefix_ok": False,
        "needs_prefix_fix": False,
        "path_ok": str(LB) in os.environ.get("PATH", "").split(os.pathsep),
        "warnings": [],
    }
    if not data["npm_found"]:
        data["warnings"].append("npm is not installed")
        return data

    try:
        result = run_text(["npm", "prefix", "-g"], timeout=10)
    except subprocess.TimeoutExpired:
        data["warnings"].append("npm prefix -g timed out")
        return data
    if result.returncode != 0:
        data["warnings"].append(f"npm prefix -g failed: {command_error(result)}")
        return data

    prefix = result.stdout.strip()
    data["prefix"] = prefix
    data["prefix_ok"] = prefix == expected
    if prefix == "/usr" or prefix.startswith("/usr/"):
        data["needs_prefix_fix"] = True
        data["warnings"].append(f"npm global prefix is {prefix}; set prefix={expected}")
    elif not data["prefix_ok"]:
        data["warnings"].append(f"npm global prefix is {prefix}; expected {expected}")
    if not data["path_ok"]:
        data["warnings"].append(f"{LB} is not on PATH")
    return data


def npm_fix_prefix() -> None:
    if not npm_have_command():
        raise SystemExit("npm is not installed")
    NPM_EXPECTED_PREFIX.mkdir(parents=True, exist_ok=True)
    run_checked(["npm", "config", "set", "prefix", str(NPM_EXPECTED_PREFIX)])


def npm_bootstrap_for_mutation() -> None:
    doctor = npm_doctor_data()
    if not doctor["npm_found"]:
        raise SystemExit("npm is required")
    if not doctor["needs_prefix_fix"]:
        return

    warning = doctor["warnings"][0] if doctor["warnings"] else "npm global prefix needs setup"
    print(f"npm doctor: {warning}")
    if sys.stdin.isatty():
        answer = input(f"Set npm prefix to {NPM_EXPECTED_PREFIX} now? [y/N] ").strip().lower()
        if answer in ("y", "yes"):
            npm_fix_prefix()
            return
    raise SystemExit("Run `dot npm doctor --fix` before installing or updating npm globals.")


def npm_installed_globals() -> tuple[dict[str, str], list[str]]:
    if not npm_have_command():
        return {}, ["npm is not installed"]
    try:
        result = run_text(["npm", "ls", "-g", "--depth=0", "--json"], timeout=20)
    except subprocess.TimeoutExpired:
        return {}, ["npm ls -g timed out"]

    if not result.stdout.strip():
        return {}, [f"npm ls -g failed: {command_error(result)}"]
    try:
        data = json.loads(result.stdout)
    except ValueError:
        return {}, ["npm ls -g returned invalid JSON"]

    warnings = []
    if result.returncode != 0:
        warnings.append(f"npm ls -g returned rc={result.returncode}: {command_error(result)}")

    installed = {}
    for name, details in (data.get("dependencies") or {}).items():
        if isinstance(details, dict):
            installed[name] = str(details.get("version") or "unknown")
    return installed, warnings


def npm_load_cache() -> Optional[dict]:
    try:
        return json.loads(NPM_STATUS_CACHE.read_text())
    except (OSError, ValueError):
        return None


def npm_cache_fresh(data: Optional[dict]) -> bool:
    if not data:
        return False
    checked_at = data.get("registry_checked_at") or data.get("generated_at") or 0
    return time.time() < float(checked_at) + int(data.get("ttl_seconds") or NPM_REGISTRY_TTL_SECONDS)


def npm_cached_latest(data: Optional[dict]) -> dict[str, dict]:
    latest = {}
    if not data:
        return latest
    for item in data.get("packages", []):
        entry = {"latest": item.get("latest"), "latest_error": item.get("latest_error")}
        if item.get("spec"):
            latest[item["spec"]] = entry
        if item.get("name"):
            latest[item["name"]] = entry
    return latest


def npm_registry_version(spec: str) -> tuple[Optional[str], Optional[str]]:
    try:
        result = run_text(["npm", "view", spec, "version", "--json"], timeout=NPM_REGISTRY_TIMEOUT_SECONDS)
    except subprocess.TimeoutExpired:
        return None, f"npm view {spec} timed out"
    if result.returncode != 0:
        return None, command_error(result)

    raw = result.stdout.strip()
    if not raw:
        return None, "npm returned no version"
    try:
        parsed = json.loads(raw)
    except ValueError:
        parsed = raw.strip('"')
    if isinstance(parsed, list):
        return (str(parsed[-1]), None) if parsed else (None, "npm returned no matching versions")
    if isinstance(parsed, str):
        return parsed, None
    return str(parsed), None


def npm_package_state(installed: Optional[str], latest: Optional[str], latest_error: Optional[str]) -> str:
    if installed is None:
        return "missing"
    if latest and installed == latest:
        return IN_SYNC
    if latest and installed != latest:
        return "outdated"
    if latest_error:
        return "unknown"
    return "unknown"


def npm_status_counts(packages: list[dict], untracked: list[dict], errors: list[str]) -> dict:
    counts = {
        "tracked": len(packages),
        "in_sync": 0,
        "outdated": 0,
        "missing": 0,
        "unknown": 0,
        "untracked": len(untracked),
        "errors": len(errors),
        "actionable": 0,
    }
    for item in packages:
        state = item.get("state")
        if state == IN_SYNC:
            counts["in_sync"] += 1
        elif state in counts:
            counts[state] += 1
    counts["actionable"] = counts["outdated"] + counts["missing"]
    return counts


def npm_build_status(query_registry: bool, cache: Optional[dict] = None) -> dict:
    now = int(time.time())
    specs, parse_warnings = npm_parse_tracked_specs()
    installed, installed_warnings = npm_installed_globals()
    cached_latest = npm_cached_latest(cache)
    packages = []
    errors = []

    for item in specs:
        latest = None
        latest_error = None
        cached = cached_latest.get(item["spec"]) or cached_latest.get(item["name"]) or {}
        if query_registry:
            latest, latest_error = npm_registry_version(item["spec"])
            if latest_error and cached.get("latest"):
                latest = cached.get("latest")
        else:
            latest = cached.get("latest")
            latest_error = cached.get("latest_error")

        if latest_error:
            errors.append(f"{item['spec']}: {latest_error}")
        installed_version = installed.get(item["name"])
        packages.append({
            "name": item["name"],
            "spec": item["spec"],
            "line": item["line"],
            "installed": installed_version,
            "latest": latest,
            "latest_error": latest_error,
            "state": npm_package_state(installed_version, latest, latest_error),
        })

    tracked_names = {item["name"] for item in specs}
    untracked = [
        {"name": name, "installed": version, "adopt_command": f"dot npm add {name}"}
        for name, version in sorted(installed.items())
        if name not in tracked_names
    ]

    registry_checked_at = now if query_registry else (
        (cache or {}).get("registry_checked_at") or (cache or {}).get("generated_at")
    )
    data = {
        "generated_at": now,
        "registry_checked_at": registry_checked_at,
        "ttl_seconds": NPM_REGISTRY_TTL_SECONDS,
        "cache_path": str(NPM_STATUS_CACHE),
        "tracked_file": str(NPM_GLOBALS_FILE),
        "source": "registry" if query_registry else ("cache" if cache else "local"),
        "doctor": npm_doctor_data(),
        "packages": packages,
        "untracked": untracked,
        "warnings": parse_warnings + installed_warnings,
        "errors": errors,
    }
    data["cache_expires_at"] = (
        int(registry_checked_at) + NPM_REGISTRY_TTL_SECONDS if registry_checked_at else None
    )
    data["counts"] = npm_status_counts(packages, untracked, errors)
    return data


def npm_write_cache(data: dict) -> None:
    NPM_STATUS_CACHE.parent.mkdir(parents=True, exist_ok=True)
    NPM_STATUS_CACHE.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")


def npm_get_status(
    force_refresh: bool = False,
    refresh_if_stale: bool = True,
    allow_registry: bool = True,
) -> dict:
    global _npm_runtime_status
    if _npm_runtime_status is not None and not force_refresh:
        return _npm_runtime_status

    cache = npm_load_cache()
    should_refresh = force_refresh or (refresh_if_stale and not npm_cache_fresh(cache))
    if allow_registry and should_refresh:
        data = npm_build_status(query_registry=True, cache=cache)
        npm_write_cache(data)
    else:
        data = npm_build_status(query_registry=False, cache=cache)
    _npm_runtime_status = data
    return data


def npm_get_waybar_status() -> dict:
    cache = npm_load_cache()
    if npm_cache_fresh(cache):
        return cache
    try:
        return npm_get_status(force_refresh=True, allow_registry=True)
    except Exception as exc:
        if cache:
            cache = dict(cache)
            cache.setdefault("errors", []).append(str(exc))
            cache["source"] = "stale-cache"
            return cache
        return {
            "generated_at": int(time.time()),
            "registry_checked_at": None,
            "ttl_seconds": NPM_REGISTRY_TTL_SECONDS,
            "cache_path": str(NPM_STATUS_CACHE),
            "tracked_file": str(NPM_GLOBALS_FILE),
            "source": "error",
            "doctor": npm_doctor_data(),
            "packages": [],
            "untracked": [],
            "warnings": [],
            "errors": [str(exc)],
            "counts": {"tracked": 0, "in_sync": 0, "outdated": 0, "missing": 0, "unknown": 0, "untracked": 0, "errors": 1, "actionable": 0},
        }


def npm_refresh_waybar() -> None:
    subprocess.run(["pkill", f"-RTMIN+{NPM_WAYBAR_SIGNAL}", "waybar"], check=False,
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


