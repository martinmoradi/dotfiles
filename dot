    print_npm_summary(data)


def npm_package_status(item: dict) -> Status:
    state = item.get("state")
    if state == IN_SYNC:
        return Status(IN_SYNC)
    if state == "outdated":
        return Status(DRIFTED)
    if state == "missing":
        return Status(NEW)
    if state == "unknown":
        return Status(SKIPPED, item.get("latest_error") or "registry status unknown")
    return Status(SKIPPED, state or "unknown")


def npm_item_label(item: dict) -> str:
    name = item["name"]
    state = item.get("state")
    installed = item.get("installed")
    latest = item.get("latest")
    if state == "outdated":
        return f"{name}    {installed} -> {latest}"
    if state == IN_SYNC:
        return f"{name}    in sync {installed}"
    if state == "missing":
        return f"{name}    missing latest {latest or 'unknown'}"
    return f"{name}    {item.get('latest_error') or 'registry status unknown'}"


def npm_tui_data() -> dict:
    return npm_get_status(refresh_if_stale=False, allow_registry=False)


def npm_refresh_button_status() -> Status:
    data = npm_tui_data()
    checked = data.get("registry_checked_at")
    if not checked:
        return Status(NEW, "no registry cache")
    age = int(time.time() - int(checked))
    if npm_cache_fresh(data):
        return Status(IN_SYNC, f"cache age {age // 60}m")
    return Status(DRIFTED, f"cache stale {age // 60}m")


def npm_update_all_status() -> Status:
    counts = npm_tui_data().get("counts", {})
    actionable = counts.get("actionable", 0)
    if actionable:
        return Status(DRIFTED, f"{actionable} package{'s' if actionable != 1 else ''}")
    return Status(IN_SYNC, "tracked packages current")


def npm_update_all_display() -> str:
    counts = npm_tui_data().get("counts", {})
    actionable = counts.get("actionable", 0)
    if actionable:
        return f"update all tracked outdated/missing ({actionable})"
    return "update all tracked outdated/missing"


def npm_package_for_tui(name: str) -> Optional[dict]:
